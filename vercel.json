{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "pages/api/worker": {
      "maxDuration": 300
    },
    "pages/api/generate": {
      "maxDuration": 30
    }
  }
}
